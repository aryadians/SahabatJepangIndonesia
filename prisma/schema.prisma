// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

enum StudentStatus {
  REGISTRATION
  TRAINING
  INTERVIEW
  COE_PROCESS
  VISA_PROCESS
  DEPARTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          UserRole  @default(STUDENT)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile Student?
}

model Student {
  id              String        @id @default(cuid())
  studentId       String        @unique // SJI-XXXX
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone           String?
  address         String?
  birthDate       DateTime?
  gender          String?
  
  status          StudentStatus @default(REGISTRATION)
  batch           String?
  
  programId       String?
  program         Program?      @relation(fields: [programId], references: [id])
  
  documents       Document[]
  payments        Payment[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Program {
  id          String    @id @default(cuid())
  name        String    @unique
  category    String    // SSW, Magang, Kursus
  description String?
  basePrice   Float
  students    Student[]
}

model Document {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name        String   // KTP, Passport, Ijazah, etc.
  fileUrl     String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  description String
  status      String   // PENDING, PAID, CANCELLED
  invoiceId   String   @unique
  createdAt   DateTime @default(now())
}
