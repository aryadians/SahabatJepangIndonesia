// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
  FINANCE
}

enum StudentStatus {
  REGISTRATION
  TRAINING
  INTERVIEW
  COE_PROCESS
  VISA_PROCESS
  DEPARTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          UserRole  @default(STUDENT)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile Student?
}

model Student {
  id              String        @id @default(cuid())
  studentId       String        @unique // SJI-XXXX
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone           String?
  address         String?
  education       String? 
  birthDate       DateTime?
  gender          String?
  
  status          StudentStatus @default(REGISTRATION)
  batch           String?
  
  programId       String?
  program         Program?      @relation(fields: [programId], references: [id])
  
  documents       Document[]
  payments        Payment[]
  grades          Grade[]
  attendance      Attendance[]
  applications    JobApplication[]
  certificates    Certificate[]
  interviews      Interview[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Program {
  id          String    @id @default(cuid())
  name        String    @unique
  category    String    // SSW, Magang, Kursus
  description String?
  basePrice   Float
  students    Student[]
  courses     Course[]
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  lessons     Lesson[]
  quizzes     Quiz[]
}

model Lesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  title     String
  content   String   // Markdown or HTML
  videoUrl  String?
  order     Int
}

model Quiz {
  id        String     @id @default(cuid())
  courseId  String
  course    Course     @relation(fields: [courseId], references: [id])
  title     String
  questions Question[]
  results   Grade[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  text          String
  options       String   // JSON string of options
  correctAnswer String
}

model Document {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name        String   
  fileUrl     String
  status      String   @default("PENDING") 
  remarks     String?  
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  description String
  status      String   
  invoiceId   String   @unique
  createdAt   DateTime @default(now())
}

model Job {
  id            String    @id @default(cuid())
  title         String
  company       String
  location      String
  sector        String
  salary        String
  description   String
  requirements  String
  status        String    @default("OPEN") 
  applications  JobApplication[]
  createdAt     DateTime  @default(now())
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  status      String   @default("APPLIED") 
  createdAt   DateTime @default(now())
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  quizId      String?
  quiz        Quiz?    @relation(fields: [quizId], references: [id])
  subject     String   
  score       Float
  type        String   
  date        DateTime @default(now())
}

model Attendance {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  date        DateTime @default(now())
  status      String   
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetBatch String?  
  createdAt   DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique 
  value     String
  type      String   @default("TEXT") 
  updatedAt DateTime @updatedAt
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  type      String   @default("MITRA") // MITRA or SO
  createdAt DateTime @default(now())
}

model Certificate {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  certNumber  String   @unique
  issueDate   DateTime @default(now())
  type        String   // COMPLETION, LANGUAGE_LEVEL
  fileUrl     String?
}

model Interview {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  companyName String
  date        DateTime
  location    String   // ZOOM, OFFICE, etc.
  link        String?  // Meeting link
  status      String   @default("SCHEDULED") // SCHEDULED, DONE, CANCELLED
}
