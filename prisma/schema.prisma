// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
  FINANCE
}

enum StudentStatus {
  REGISTRATION
  TRAINING
  INTERVIEW
  COE_PROCESS
  VISA_PROCESS
  DEPARTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          UserRole  @default(STUDENT)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile Student?
}

model Student {
  id              String        @id @default(cuid())
  studentId       String        @unique // SJI-XXXX
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone           String?
  address         String?
  education       String? // SMA/SMK, Diploma, Sarjana
  birthDate       DateTime?
  gender          String?
  
  status          StudentStatus @default(REGISTRATION)
  batch           String?
  
  programId       String?
  program         Program?      @relation(fields: [programId], references: [id])
  
  documents       Document[]
  payments        Payment[]
  grades          Grade[]
  attendance      Attendance[]
  applications    JobApplication[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Program {
  id          String    @id @default(cuid())
  name        String    @unique
  category    String    // SSW, Magang, Kursus
  description String?
  basePrice   Float
  students    Student[]
}

model Document {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name        String   // KTP, Passport, Ijazah, etc.
  fileUrl     String
  status      String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  remarks     String?  // Reason for rejection
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  description String
  status      String   // PENDING, PAID, CANCELLED
  invoiceId   String   @unique
  createdAt   DateTime @default(now())
}

model Job {
  id            String    @id @default(cuid())
  title         String
  company       String
  location      String
  sector        String
  salary        String
  description   String
  requirements  String
  status        String    @default("OPEN") // OPEN, CLOSED
  applications  JobApplication[]
  createdAt     DateTime  @default(now())
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  status      String   @default("APPLIED") // APPLIED, INTERVIEW, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  subject     String   // JLPT N4, JFT-Basic, etc.
  score       Float
  type        String   // TRY_OUT, FINAL_EXAM
  date        DateTime @default(now())
}

model Attendance {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  date        DateTime @default(now())
  status      String   // PRESENT, ABSENT, PERMIT, SICK
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetBatch String?  // Specific batch or null for all
  createdAt   DateTime @default(now())
}
